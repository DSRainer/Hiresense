{
  "editor.formatOnSave": true,

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  "css.customData": [
    "./.vscode/tailwind.json"
  ],

  "files.associations": {
    "*.css": "tailwindcss"
  },

  "tailwindCSS.experimental.configFile": null,

  "editor.quickSuggestions": {
    "strings": true
  }
}